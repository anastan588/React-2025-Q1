{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["vitest"],
    "plugins": [{ "name": "next" }],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noEmit": false,
    "incremental": true,
    "esModuleInterop": true,
    "composite": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true,
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "$/*": ["*"]
    }
  },

  "include": [
    "next-env.d.ts",
    "./dist/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "pages",
    "components",
    "public/sounds",
    "public/images",
    "public/icons",
    "public/fonts",
    "globals.d.ts",
    "files.d.ts"
  ],
  "exclude": ["node_modules"]
}
